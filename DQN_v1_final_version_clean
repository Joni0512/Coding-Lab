    )

    root_save = os.path.join(os.getcwd(), "seed_sweep_gamma_0_929")
    os.makedirs(root_save, exist_ok=True)

    results = []

    for seed in SEEDS:
        # reproducibility
        os.environ["PYTHONHASHSEED"] = str(seed)
