# Plot helpers
def moving_average(x, window=25):
    x = np.asarray(x, dtype=np.float32)
    if len(x) < window:
        return None
    return np.convolve(x, np.ones(window, dtype=np.float32)/window, mode="valid")

def plot_train_val_test(train_returns, val_returns, test_returns,
                        benchmark=None, ma_window=25, title="Returns",
                        save_path=None, show=False):
    train_returns = np.asarray(train_returns, dtype=np.float32)
    val_returns   = np.asarray(val_returns, dtype=np.float32)
    test_returns  = np.asarray(test_returns, dtype=np.float32)

    x_train = np.arange(1, len(train_returns)+1)
    x_val   = np.arange(len(train_returns)+1, len(train_returns)+len(val_returns)+1)
    x_test  = np.arange(len(train_returns)+len(val_returns)+1,
                        len(train_returns)+len(val_returns)+len(test_returns)+1)

    plt.figure()
    if len(train_returns): plt.plot(x_train, train_returns, label="Train")
    if len(val_returns):   plt.plot(x_val,   val_returns,   label="Val (greedy)")
    if len(test_returns):  plt.plot(x_test,  test_returns,  label="Test (greedy)")

    ma = moving_average(train_returns, ma_window)
    if ma is not None:
        plt.plot(np.arange(ma_window, len(train_returns)+1), ma, label=f"Train {ma_window}-MA")

    if benchmark is not None:
        plt.axhline(benchmark, linestyle="--", label=f"Benchmark {benchmark:.1f}")

    plt.xlabel("Episode (Train+Val+Test)")
    plt.ylabel("Return")
    plt.title(title)
    plt.legend()
    plt.tight_layout()

    if save_path:
        plt.savefig(save_path, dpi=150)
    if show:
        plt.show()
    plt.close()

